name: lemonade

services:
  lemonade-server:
    container_name: lemonade-server
    build: .
    # Or use a pre-built image:
    # image: ghcr.io/boecks/lemonade-docker:latest
    restart: unless-stopped
    ports:
      - "13305:13305"
      - "9000:9000"
    volumes:
      # Model cache (HuggingFace downloads)
      - ./models:/models
      # Lemonade config (keepalive_options.json, recipe_options.json)
      - ./lemonade-data:/var/lib/lemonade/.cache/lemonade
      # Optional: custom llama-server binary (e.g. ROCm build)
      # - ./llamacpp:/backends
    environment:
      - HF_HOME=/models
      #- HF_TOKEN=
      #- LEMONADE_HOST=0.0.0.0
      #- LEMONADE_PORT=13305
      # GPU backend: rocm, vulkan, or omit for CPU
      #- LEMONADE_LLAMACPP=rocm
      # Optional: custom llama-server binary path
      # - LEMONADE_LLAMACPP_ROCM_BIN=/backends/rocm/llama-server
      # Optional: global defaults (can also be set per-model in recipe_options.json)
      # - LEMONADE_CTX_SIZE=8192
      # - LEMONADE_LLAMACPP_ARGS=--flash-attn on --no-mmap
    # AMD GPU passthrough (adjust for your system)
    devices:
      - /dev/kfd
      - /dev/dri/renderD128
      - /dev/dri/card0